export default function AdminConsole() {
  const [activeTab, setActiveTab] = useState("Users");

  const [users, setUsers] = useState(INITIAL_USERS);
  const [bans, setBans] = useState(INITIAL_BANS);
  const [imports, setImports] = useState(INITIAL_IMPORTS);
  const [updates, setUpdates] = useState(INITIAL_UPDATES);
  const [suggestions, setSuggestions] = useState(INITIAL_SUGGESTIONS);

  const [newImportTitle, setNewImportTitle] = useState("");
  const [newImportDescription, setNewImportDescription] = useState("");

  const [newUpdateTitle, setNewUpdateTitle] = useState("");
  const [newUpdateDescription, setNewUpdateDescription] = useState("");

  const [selectedUserId, setSelectedUserId] = useState(null);
  const [selectedRank, setSelectedRank] = useState("User");

  const [banUserName, setBanUserName] = useState("");
  const [banReason, setBanReason] = useState("");

  const [suggestionFilter, setSuggestionFilter] = useState("All");

  // USERS TAB ACTIONS
  const handleDeleteUser = (id) => {
    setUsers((prev) => prev.filter((u) => u.id !== id));
  };

  const handleToggleBanUser = (id) => {
    setUsers((prev) =>
      prev.map((u) =>
        u.id === id ? { ...u, banned: !u.banned } : u
      )
    );
  };

  // BANS TAB ACTIONS
  const handleAddBan = () => {
    if (!banUserName.trim() || !banReason.trim()) return;
    const newBan = {
      id: Date.now(),
      userName: banUserName.trim(),
      reason: banReason.trim(),
      date: new Date().toISOString().slice(0, 10),
    };
    setBans((prev) => [newBan, ...prev]);
    setBanUserName("");
    setBanReason("");
  };

  const handleRemoveBan = (id) => {
    setBans((prev) => prev.filter((b) => b.id !== id));
  };

  // IMPORTS TAB ACTIONS
  const handleAddImport = () => {
    if (!newImportTitle.trim() || !newImportDescription.trim()) return;
    const newItem = {
      id: Date.now(),
      title: newImportTitle.trim(),
      description: newImportDescription.trim(),
      date: new Date().toISOString().slice(0, 10),
    };
    setImports((prev) => [newItem, ...prev]);
    setNewImportTitle("");
    setNewImportDescription("");
  };

  // UPDATES TAB ACTIONS
  const handleAddUpdate = () => {
    if (!newUpdateTitle.trim() || !newUpdateDescription.trim()) return;
    const newItem = {
      id: Date.now(),
      title: newUpdateTitle.trim(),
      description: newUpdateDescription.trim(),
      date: new Date().toISOString().slice(0, 10),
    };
    setUpdates((prev) => [newItem, ...prev]);
    setNewUpdateTitle("");
    setNewUpdateDescription("");
  };

  // RANKS TAB ACTIONS
  const handleApplyRank = () => {
    if (!selectedUserId) return;
    setUsers((prev) =>
      prev.map((u) =>
        u.id === Number(selectedUserId) ? { ...u, rank: selectedRank } : u
      )
    );
  };

  // SUGGESTIONS TAB ACTIONS
  const handleChangeSuggestionStatus = (id, status) => {
    setSuggestions((prev) =>
      prev.map((s) =>
        s.id === id ? { ...s, status } : s
      )
    );
  };

  const filteredSuggestions =
    suggestionFilter === "All"
      ? suggestions
      : suggestions.filter((s) => s.status === suggestionFilter);

  return (
    <div className="min-h-screen bg-gradient-to-b from-slate-900 to-black text-white p-6">
      {/* HEADER */}
      <h1 className="text-4xl font-bold text-center mb-2">Admin Console</h1>
      <p className="text-center text-white/60 mb-8">
        Manage users, bans, imports, updates, suggestions, and ranks for Grayon Hub.
      </p>

      {/* TABS */}
      <div className="flex flex-wrap justify-center gap-3 mb-8">
        {TABS.map((tab) => (
          <button
            key={tab}
            onClick={() => setActiveTab(tab)}
            className={`px-4 py-2 rounded-lg border text-sm md:text-base transition ${
              activeTab === tab
                ? "bg-blue-600 border-blue-400"
                : "bg-white/10 border-white/20 hover:bg-white/20"
            }`}
          >
            {tab}
          </button>
        ))}
      </div>

      {/* ACTIVE TAB CONTENT */}
      <div className="max-w-6xl mx-auto bg-white/5 border border-white/10 rounded-xl p-6">
        {activeTab === "Users" && (
          <UsersTab
            users={users}
            onDeleteUser={handleDeleteUser}
            onToggleBanUser={handleToggleBanUser}
          />
        )}

        {activeTab === "Bans" && (
          <BansTab
            bans={bans}
            banUserName={banUserName}
            banReason={banReason}
            setBanUserName={setBanUserName}
            setBanReason={setBanReason}
            onAddBan={handleAddBan}
            onRemoveBan={handleRemoveBan}
          />
        )}

        {activeTab === "Imports" && (
          <ImportsTab
            imports={imports}
            newImportTitle={newImportTitle}
            newImportDescription={newImportDescription}
            setNewImportTitle={setNewImportTitle}
            setNewImportDescription={setNewImportDescription}
            onAddImport={handleAddImport}
          />
        )}

        {activeTab === "Updates" && (
          <UpdatesTab
            updates={updates}
            newUpdateTitle={newUpdateTitle}
            newUpdateDescription={newUpdateDescription}
            setNewUpdateTitle={setNewUpdateTitle}
            setNewUpdateDescription={setNewUpdateDescription}
            onAddUpdate={handleAddUpdate}
          />
        )}

        {activeTab === "Suggestions" && (
          <SuggestionsTab
            suggestions={filteredSuggestions}
            suggestionFilter={suggestionFilter}
            setSuggestionFilter={setSuggestionFilter}
            onChangeSuggestionStatus={handleChangeSuggestionStatus}
          />
        )}

        {activeTab === "Ranks" && (
          <RanksTab
            users={users}
            ranks={RANKS}
            selectedUserId={selectedUserId}
            setSelectedUserId={setSelectedUserId}
            selectedRank={selectedRank}
            setSelectedRank={setSelectedRank}
            onApplyRank={handleApplyRank}
          />
        )}
      </div>
    </div>
  );
}

