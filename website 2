const FavoritesContext = createContext();

export function FavoritesProvider({ children }) {
  const { user } = useAuth();
  const [favorites, setFavorites] = useState({});

  // Load saved favorites
  useEffect(() => {
    const saved = localStorage.getItem("glora_favorites");
    if (saved) setFavorites(JSON.parse(saved));
  }, []);

  // Save favorites
  useEffect(() => {
    localStorage.setItem("glora_favorites", JSON.stringify(favorites));
  }, [favorites]);

  const toggleFavorite = (gameId) => {
    if (!user) return;

    setFavorites((prev) => {
      const userFavs = prev[user.email] || [];
      const updated = userFavs.includes(gameId)
        ? userFavs.filter((id) => id !== gameId)
        : [...userFavs, gameId];

      return {
        ...prev,
        [user.email]: updated,
      };
    });
  };

  const isFavorite = (gameId) => {
    if (!user) return false;
    return favorites[user.email]?.includes(gameId) || false;
  };

  const getUserFavorites = () => {
    if (!user) return [];
    return favorites[user.email] || [];
  };

  return (
    <FavoritesContext.Provider
      value={{ toggleFavorite, isFavorite, getUserFavorites }}
    >
      {children}
    </FavoritesContext.Provider>
  );
}

