import React, { createContext, useContext, useState, useEffect } from "react";
import { useAuth } from "./AuthContext";

const AchievementsContext = createContext();

export function AchievementsProvider({ children }) {
  const { user } = useAuth();
  const [data, setData] = useState({});

  // Load saved data
  useEffect(() => {
    const saved = localStorage.getItem("glora_achievements");
    if (saved) setData(JSON.parse(saved));
  }, []);

  // Save data
  useEffect(() => {
    localStorage.setItem("glora_achievements", JSON.stringify(data));
  }, [data]);

  const getUserData = (email) => {
    return data[email] || { xp: 0, achievements: [] };
  };

  const addXP = (email, amount) => {
    setData((prev) => {
      const userData = prev[email] || { xp: 0, achievements: [] };
      return {
        ...prev,
        [email]: {
          ...userData,
          xp: userData.xp + amount,
        },
      };
    });
  };

  const unlockAchievement = (email, achievementId) => {
    setData((prev) => {
      const userData = prev[email] || { xp: 0, achievements: [] };
      if (userData.achievements.includes(achievementId)) return prev;

      return {
        ...prev,
        [email]: {
          ...userData,
          achievements: [...userData.achievements, achievementId],
        },
      };
    });
  };

  const getLevel = (xp) => {
    return Math.floor(xp / 100) + 1; // 100 XP per level
  };

  return (
    <AchievementsContext.Provider
      value={{ getUserData, addXP, unlockAchievement, getLevel }}
    >
      {children}
    </AchievementsContext.Provider>
  );
}

export function useAchievements() {
  return useContext(AchievementsContext);
}
