import { ArrowLeft, Gamepad2, Search, Star, X, Maximize2, Minimize2, Upload, AlertTriangle, Crown, Settings, User, File, Link as LinkIcon, Activity, MessageSquare, Shield, LogOut } from 'lucide-react';
import { Input } from '@/components/ui/input';
