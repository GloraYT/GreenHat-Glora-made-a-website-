          ratings: {
            ...game.ratings,
            [userEmail]: rating,
          },
        },
      };
    });
  };

  const commentOnGame = (gameId, userEmail, text) => {
    setFeedback((prev) => {
      const game = prev[gameId] || { ratings: {}, comments: [] };
      return {
        ...prev,
        [gameId]: {
          ...game,
          comments: [
            ...game.comments,
            {
              user: userEmail,
              text,
              time: Date.now(),
            },
          ],
        },
      };
    });
  };

  return (
    <FeedbackContext.Provider value={{ feedback, rateGame, commentOnGame }}>
      {children}
