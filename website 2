export default function Games() {
  const navigate = useNavigate();
  const [selectedCategory, setSelectedCategory] = useState('all');
  const [searchQuery, setSearchQuery] = useState('');
  const [activeGame, setActiveGame] = useState(null);
  const [isFullscreen, setIsFullscreen] = useState(false);
  const [customGames, setCustomGames] = useState([]);
  const [showImportDialog, setShowImportDialog] = useState(false);
  const [importMode, setImportMode] = useState('url');
  const [importUrl, setImportUrl] = useState('');
  const [importName, setImportName] = useState('');
  const [globalRatings, setGlobalRatings] = useState({});
  const [adsEnabled, setAdsEnabled] = useState(false);
  const [currentUser, setCurrentUser] = useState(null);
  const [gameAccessUnlocked, setGameAccessUnlocked] = useState(false);
  const [gameAccessCode, setGameAccessCode] = useState('');
  const [showSuggestionDialog, setShowSuggestionDialog] = useState(false);
  const [suggestionText, setSuggestionText] = useState('');
  const [suggestionType, setSuggestionType] = useState('suggestion');
  const iframeRef = useRef(null);

  useEffect(() => {
    const user = localStorage.getItem('glora_user');
    if (user) setCurrentUser(JSON.parse(user));
    const unlocked = localStorage.getItem('game_center_unlocked');
    if (unlocked === 'true') setGameAccessUnlocked(true);
    loadGlobalRatings();
  }, []);

  const handleGameCenterCode = async () => {
    if (gameAccessCode === '1234') {
      setGameAccessUnlocked(true);
      localStorage.setItem('game_center_unlocked', 'true');
    } else {
      // Log failed attempt
      try {
        await base44.entities.FailedCode.create({
          attempted_code: gameAccessCode,
          username: currentUser?.username || 'guest',
          area: 'game_center'
        });
      } catch {}
      alert('Wrong code!');
    }
    setGameAccessCode('');
  };

  const handleSubmitSuggestion = async () => {
    if (!suggestionText.trim()) return;
    await base44.entities.SuggestionReport.create({
      type: suggestionType,
      message: suggestionText,
      username: currentUser?.username || 'anonymous',
      status: 'pending'
    });
    setSuggestionText('');
    setShowSuggestionDialog(false);
    alert('Submitted! Thanks!');
  };

  const loadGlobalRatings = async () => {
    try {
      const ratings = await base44.entities.GameRating.list();
      const ratingMap = {};
      ratings.forEach(r => {
        if (!ratingMap[r.game_id]) {
          ratingMap[r.game_id] = { total: 0, count: 0 };
        }
        ratingMap[r.game_id].total += r.rating;
        ratingMap[r.game_id].count += 1;
      });
      Object.keys(ratingMap).forEach(key => {
        ratingMap[key] = Math.round(ratingMap[key].total / ratingMap[key].count);
      });
      setGlobalRatings(ratingMap);
    } catch (err) {
      console.log('No ratings yet');
    }
  };

  const allGames = [...getAllGames(), ...customGames];
  
  const filteredGames = allGames.filter(g => {
    const matchesCategory = selectedCategory === 'all' || g.category === selectedCategory;
    const matchesSearch = g.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
                          g.description.toLowerCase().includes(searchQuery.toLowerCase());
    return matchesCategory && matchesSearch;
  });

  const getCounts = () => {
    return categories.map(cat => ({
      ...cat,
      count: cat.id === 'all' ? allGames.length : allGames.filter(g => g.category === cat.id).length
    }));
  };

  const playGame = (game) => {
    if (game.url) {
      setActiveGame(game);
    }
  };

  const handleImportGame = () => {
    if (importUrl && importName) {
      const newGame = {
        id: `custom-${Date.now()}`,
        name: importName,
        description: 'Custom imported game',
        url: importUrl,
        category: 'browser',
        color: 'from-yellow-500 to-orange-600'
      };
      setCustomGames(prev => [...prev, newGame]);
      setShowImportDialog(false);
      setImportUrl('');
      setImportName('');
    }
  };

  const rateGame = async (gameId, rating) => {
    if (!currentUser) {
      alert('Please login to rate games!');
      navigate(createPageUrl('GloraLogin'));
      return;
    }
    try {
      const existing = await base44.entities.GameRating.filter({ game_id: gameId, username: currentUser.username });
      if (existing.length > 0) {
        await base44.entities.GameRating.update(existing[0].id, { rating });
      } else {
        await base44.entities.GameRating.create({ game_id: gameId, username: currentUser.username, rating });
      }
      loadGlobalRatings();
    } catch (err) {
      console.error(err);
    }
  };

  const toggleFullscreen = () => {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen();
      setIsFullscreen(true);
    } else {
      document.exitFullscreen();
      setIsFullscreen(false);
    }
  };

  // Gate: require access code
  if (!gameAccessUnlocked) {
    return (
      <div className="min-h-screen bg-[#0a0a0a] text-white flex items-center justify-center">
        <div className="bg-[#1a1a1a] border border-cyan-500/30 rounded-2xl p-8 max-w-sm w-full text-center">
          <div className="text-4xl mb-4">🎮</div>
          <h2 className="text-xl font-black mb-2">Enter Access Code</h2>
          <p className="text-gray-400 text-sm mb-4">You need a code to enter the Game Center.</p>
          <Input
            type="password"
            placeholder="Enter code..."
            value={gameAccessCode}
            onChange={e => setGameAccessCode(e.target.value)}
            onKeyDown={e => e.key === 'Enter' && handleGameCenterCode()}
            className="bg-black/50 border-white/10 text-white mb-3"
          />
          <button onClick={handleGameCenterCode} className="w-full py-2 bg-gradient-to-r from-cyan-500 to-purple-500 text-white rounded-lg font-bold">Enter</button>
          <Link to={createPageUrl('Home')} className="block mt-3 text-gray-500 text-sm hover:text-white">← Back to Home</Link>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-[#0a0a0a] text-white">
      {/* Suggestion Dialog */}
      <Dialog open={showSuggestionDialog} onOpenChange={setShowSuggestionDialog}>
        <DialogContent className="bg-[#1a1a1a] border-white/10">
          <DialogHeader>
            <DialogTitle className="text-white">What Should We Add?/Change</DialogTitle>
          </DialogHeader>
          <div className="space-y-3">
            <div className="flex gap-2">
              <button onClick={() => setSuggestionType('suggestion')} className={`flex-1 py-2 rounded-lg text-sm ${suggestionType === 'suggestion' ? 'bg-purple-500' : 'bg-white/10'}`}>Suggestion</button>
              <button onClick={() => setSuggestionType('report')} className={`flex-1 py-2 rounded-lg text-sm ${suggestionType === 'report' ? 'bg-red-500' : 'bg-white/10'}`}>Report</button>
            </div>
            <textarea
              placeholder="What should we add or change?"
              value={suggestionText}
              onChange={e => setSuggestionText(e.target.value)}
              className="w-full bg-black/50 border border-white/10 rounded-lg p-3 text-white text-sm resize-none h-32"
            />
            <button onClick={handleSubmitSuggestion} className="w-full py-2 bg-gradient-to-r from-purple-500 to-pink-500 text-white rounded-lg font-bold">Submit</button>
          </div>
        </DialogContent>
      </Dialog>

      {/* Virus Warning */}
      <div className="bg-yellow-500/10 border-b border-yellow-500/20 px-4 py-2">
        <div className="max-w-7xl mx-auto flex items-center gap-2 text-yellow-400 text-sm">
          <AlertTriangle className="w-4 h-4" />
          <span>⚠️ CAUTION: If a game shows virus/malware warning, exit and try again. If it persists, DO NOT open that game!</span>
        </div>
      </div>

      {/* Import Game Dialog */}
      <Dialog open={showImportDialog} onOpenChange={setShowImportDialog}>
        <DialogContent className="bg-[#1a1a1a] border-white/10">
          <DialogHeader>
            <DialogTitle className="text-white flex items-center gap-2">
              <Upload className="w-5 h-5" />
              Import Your Own Game
            </DialogTitle>
          </DialogHeader>
          <div className="space-y-4">
            {/* Mode Toggle */}
            <div className="flex gap-2">
              <button
                onClick={() => setImportMode('url')}
                className={`flex-1 py-2 rounded-lg flex items-center justify-center gap-2 ${importMode === 'url' ? 'bg-cyan-500' : 'bg-white/10'}`}
              >
                <LinkIcon className="w-4 h-4" />
                URL
              </button>
              <button
                onClick={() => setImportMode('file')}
                className={`flex-1 py-2 rounded-lg flex items-center justify-center gap-2 ${importMode === 'file' ? 'bg-cyan-500' : 'bg-white/10'}`}
              >
                <File className="w-4 h-4" />
                File
              </button>
            </div>

            <Input
              placeholder="Game name..."
              value={importName}
              onChange={(e) => setImportName(e.target.value)}
              className="bg-black/50 border-white/10 text-white"
            />

            {importMode === 'url' ? (
              <Input
                placeholder="Game URL (must be embeddable)..."
                value={importUrl}
