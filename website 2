}import React, { useState, useEffect } from 'react';
import { motion } from 'framer-motion';
import { Link, useNavigate } from 'react-router-dom';
import { createPageUrl } from '@/utils';
import { ArrowLeft, User, Lock, AlertCircle, CheckCircle, LogOut } from 'lucide-react';
import { Input } from '@/components/ui/input';
import { base44 } from '@/api/base44Client';
import { containsProfanity, isValidUsername } from '@/components/profanityFilter';

// Reserved usernames with special ranks
const reservedUsers = {
  'glora': { rank: 'owner', color: 'text-cyan-400' },
  'greenhat': { rank: 'creator/ideas man', color: 'text-green-400' },
  'riptide': { rank: 'lower_admin', color: 'text-red-400' },
  'jaydengarcia': { rank: 'lower_moderator', color: 'text-orange-400' },
  'jayden garcia': { rank: 'lower_moderator', color: 'text-orange-400' },
};

export default function GloraLogin() {
  const navigate = useNavigate();
  const [mode, setMode] = useState('login');
  const [username, setUsername] = useState('');
  const [password, setPassword] = useState('');
  const [error, setError] = useState('');
  const [success, setSuccess] = useState('');
  const [loading, setLoading] = useState(false);
  const [currentUser, setCurrentUser] = useState(null);

  useEffect(() => {
    const u = localStorage.getItem('glora_user');
    if (u) setCurrentUser(JSON.parse(u));
  }, []);

  const getDeviceId = () => {
    let deviceId = localStorage.getItem('glora_device_id');
    if (!deviceId) {
      deviceId = 'device_' + Math.random().toString(36).substr(2, 9) + Date.now();
      localStorage.setItem('glora_device_id', deviceId);
    }
    return deviceId;
  };

  const checkBan = async (username, deviceId) => {
    const now = new Date().toISOString();
    // Check username ban
    const userBans = await base44.entities.BanRecord.filter({ username: username.toLowerCase(), is_active: true });
    const activeBan = userBans.find(b => !b.unban_date || b.unban_date > now);
    if (activeBan) return activeBan;
    // Check IP ban
    if (deviceId) {
      const allBans = await base44.entities.BanRecord.filter({ is_ip_ban: true, is_active: true });
      const ipBan = allBans.find(b => b.device_id === deviceId && (!b.unban_date || b.unban_date > now));
      if (ipBan) return ipBan;
    }
    return null;
  };

  const handleSignup = async () => {
    setError(''); setSuccess('');
    if (!username || !password) { setError('Please fill in all fields'); return; }
    if (username.length < 3) { setError('Username must be at least 3 characters'); return; }
    if (!isValidUsername(username)) { setError('Username can only contain letters, numbers, and underscores'); return; }
    if (containsProfanity(username)) { setError('Username contains inappropriate language'); return; }
    if (password.length < 4) { setError('Password must be at least 4 characters'); return; }

    setLoading(true);
    const deviceId = getDeviceId();

    // Check if device is banned
    const ban = await checkBan(username.toLowerCase(), deviceId);
    if (ban) {
      setError(`This device/account is banned: ${ban.reason}`);
      setLoading(false);
      return;
    }

    // Check device account limit
    const deviceAccounts = await base44.entities.GloraAccount.filter({ device_id: deviceId });
    if (deviceAccounts.length >= 2) {
      setError('You can only have 2 accounts per device');
      setLoading(false);
      return;
    }

    // Check username exists
    const existing = await base44.entities.GloraAccount.filter({ username: username.toLowerCase() });
    if (existing.length > 0) { setError('Username already taken'); setLoading(false); return; }

    const lowerUsername = username.toLowerCase();
    // Check for jayden garcia variations
    const isJayden = ['jaydengarcia', 'jayden garcia', 'jayden_garcia'].includes(lowerUsername);
    const reserved = reservedUsers[lowerUsername] || (isJayden ? { rank: 'lower_moderator', color: 'text-orange-400' } : null);

    const newAccount = await base44.entities.GloraAccount.create({
      username: lowerUsername,
      password,
      rank: reserved ? reserved.rank : 'user',
      rank_color: reserved ? reserved.color : 'text-gray-400',
      device_id: deviceId
    });

    localStorage.setItem('glora_user', JSON.stringify({
      id: newAccount.id,
      username: newAccount.username,
      rank: newAccount.rank,
      rank_color: newAccount.rank_color
    }));

    setSuccess('Account created! Redirecting...');
    setTimeout(() => navigate(createPageUrl('Games')), 1500);
    setLoading(false);
  };

  const handleLogin = async () => {
    setError(''); setSuccess('');
    if (!username || !password) { setError('Please fill in all fields'); return; }
    setLoading(true);

    const deviceId = getDeviceId();
    const accounts = await base44.entities.GloraAccount.filter({ username: username.toLowerCase() });
    if (accounts.length === 0) { setError('Account not found'); setLoading(false); return; }

    const account = accounts[0];
    if (account.password !== password) { setError('Wrong password'); setLoading(false); return; }

    // Check ban
    const ban = await checkBan(account.username, account.device_id || deviceId);
    if (ban) {
      const banEnd = ban.unban_date ? new Date(ban.unban_date).toLocaleDateString() : 'forever';
      setError(`Account banned until ${banEnd}. Reason: ${ban.reason}`);
      setLoading(false);
      return;
    }

    localStorage.setItem('glora_user', JSON.stringify({
      id: account.id,
      username: account.username,
      rank: account.rank,
      rank_color: account.rank_color
    }));

    setSuccess('Logged in! Redirecting...');
    setTimeout(() => navigate(createPageUrl('Games')), 1500);
    setLoading(false);
  };

  const handleLogout = () => {
    localStorage.removeItem('glora_user');
    setCurrentUser(null);
    setSuccess('Logged out!');
  };

  return (
    <div className="min-h-screen bg-[#0a0a0a] text-white flex items-center justify-center p-4">
      <div className="fixed inset-0 bg-gradient-to-br from-purple-900/20 via-transparent to-cyan-900/20" />

      <motion.div className="relative z-10 w-full max-w-md" initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }}>
        <Link to={createPageUrl('Games')} className="flex items-center gap-2 text-gray-400 hover:text-cyan-400 mb-6">
          <ArrowLeft className="w-5 h-5" />
          Back to Games
        </Link>

        <div className="bg-[#1a1a1a] border border-white/10 rounded-2xl p-8">
          <h1 className="text-2xl font-black text-center mb-6">
            <span className="bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent">GLORA</span>
            <span className="text-white ml-2">Account</span>
          </h1>

          {/* If logged in, show profile + logout */}
          {currentUser ? (
            <div className="text-center space-y-4">
              <div className="text-2xl font-black text-white">{currentUser.username}</div>
              <div className={`text-sm font-bold capitalize ${currentUser.rank_color || 'text-gray-400'}`}>{currentUser.rank}</div>
              {['owner','creator/ideas man','lower_admin','lower_moderator'].includes(currentUser.rank) && (
                <Link to={createPageUrl('AdminConsole')} className="block py-2 bg-cyan-500/20 text-cyan-400 rounded-lg text-sm font-bold hover:bg-cyan-500/30">
                  🛡️ Admin Console
                </Link>
              )}
              <button
                onClick={handleLogout}
                className="w-full py-3 bg-red-500/20 text-red-400 rounded-lg font-bold flex items-center justify-center gap-2 hover:bg-red-500/30"
              >
                <LogOut className="w-4 h-4" />
                Log Out
              </button>
              {success && <div className="text-green-400 text-sm">{success}</div>}
            </div>
          ) : (
            <>
              {/* Mode Toggle */}
              <div className="flex gap-2 mb-6">
                <button onClick={() => setMode('login')} className={`flex-1 py-2 rounded-lg font-bold transition-all ${mode === 'login' ? 'bg-gradient-to-r from-cyan-500 to-purple-500 text-white' : 'bg-white/5 text-gray-400'}`}>Login</button>
                <button onClick={() => setMode('signup')} className={`flex-1 py-2 rounded-lg font-bold transition-all ${mode === 'signup' ? 'bg-gradient-to-r from-cyan-500 to-purple-500 text-white' : 'bg-white/5 text-gray-400'}`}>Sign Up</button>
              </div>

              {error && (
                <div className="flex items-center gap-2 text-red-400 text-sm mb-4 bg-red-500/10 p-3 rounded-lg">
                  <AlertCircle className="w-4 h-4" />{error}
                </div>
              )}
              {success && (
                <div className="flex items-center gap-2 text-green-400 text-sm mb-4 bg-green-500/10 p-3 rounded-lg">
                  <CheckCircle className="w-4 h-4" />{success}
                </div>
              )}

              <div className="space-y-4">
                <div className="relative">
                  <User className="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" />
                  <Input placeholder="Username" value={username} onChange={e => setUsername(e.target.value)} className="pl-10 bg-black/50 border-white/10 text-white" />
                </div>
                <div className="relative">
                  <Lock className="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" />
                  <Input type="password" placeholder="Password" value={password} onChange={e => setPassword(e.target.value)} className="pl-10 bg-black/50 border-white/10 text-white" onKeyDown={e => e.key === 'Enter' && (mode === 'login' ? handleLogin() : handleSignup())} />
                </div>
                <button
                  onClick={mode === 'login' ? handleLogin : handleSignup}
                  disabled={loading}
                  className="w-full py-3 bg-gradient-to-r from-cyan-500 to-purple-500 text-white rounded-lg font-bold hover:opacity-90 disabled:opacity-50"
                >
                  {loading ? 'Loading...' : mode === 'login' ? 'Login' : 'Create Account'}
                </button>
              </div>

              {mode === 'signup' && (
                <p className="text-gray-500 text-xs text-center mt-4">Max 2 accounts per device. No inappropriate usernames.</p>
              )}
            </>
          )}
        </div>
      </motion.div>
    </div>
  );
}import React, { useState, useRef, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { Link, useNavigate } from 'react-router-dom';
