import React, { createContext, useContext, useState, useEffect } from "react";
import { useAuth } from "./AuthContext";

const NotificationsContext = createContext();

export function NotificationsProvider({ children }) {
  const { user } = useAuth();
  const [notifications, setNotifications] = useState({});

  // Load saved notifications
  useEffect(() => {
    const saved = localStorage.getItem("glora_notifications");
    if (saved) setNotifications(JSON.parse(saved));
  }, []);

  // Save notifications
  useEffect(() => {
    localStorage.setItem("glora_notifications", JSON.stringify(notifications));
  }, [notifications]);

  const addNotification = (email, message) => {
    setNotifications((prev) => {
      const userNotes = prev[email] || [];
      return {
        ...prev,
        [email]: [
          {
            id: Date.now(),
            message,
            time: Date.now(),
            read: false,
          },
          ...userNotes,
        ],
      };
    });
  };

  const markAsRead = (email, id) => {
    setNotifications((prev) => {
      const userNotes = prev[email] || [];
      return {
        ...prev,
        [email]: userNotes.map((n) =>
          n.id === id ? { ...n, read: true } : n
        ),
      };
    });
  };

  const clearAll = (email) => {
    setNotifications((prev) => ({
      ...prev,
      [email]: [],
    }));
  };

  const getUserNotifications = () => {
    if (!user) return [];
    return notifications[user.email] || [];
  };

  return (
    <NotificationsContext.Provider
      value={{ addNotification, markAsRead, clearAll, getUserNotifications }}
    >
      {children}
    </NotificationsContext.Provider>
  );
}

