}import React, { useState, useEffect } from 'react';
import { motion } from 'framer-motion';
import { Link, useNavigate } from 'react-router-dom';
import { createPageUrl } from '@/utils';
import { 
  ArrowLeft, Shield, Ban, Globe, AlertTriangle, MessageSquare, 
  Users, Plus, Trash2, Eye, CheckCircle, Clock, Search,
  PlusCircle, X, Star, Activity
} from 'lucide-react';
import { Input } from '@/components/ui/input';
import { Textarea } from '@/components/ui/textarea';
import { base44 } from '@/api/base44Client';

const TABS = [
  { id: 'accounts', label: 'Accounts', icon: Users },
  { id: 'ban', label: 'Ban Console', icon: Ban },
  { id: 'failed_codes', label: 'Failed Codes', icon: AlertTriangle },
  { id: 'web_import', label: 'Web Import', icon: Globe },
  { id: 'suggestions', label: 'What Should We Add', icon: MessageSquare },
  { id: 'updates', label: 'Update Log', icon: Activity },
];

// Ranks that can access admin console
const ADMIN_RANKS = ['owner', 'creator/ideas man', 'lower_admin', 'lower_moderator'];
// Jayden Garcia (lower_moderator) can see page but buttons don't work
// lower_admin (riptide) can VIEW but NOT ban

export default function AdminConsole() {
  const navigate = useNavigate();
  const [currentUser, setCurrentUser] = useState(null);
  const [activeTab, setActiveTab] = useState('accounts');
  const [loading, setLoading] = useState(true);

  // Data states
  const [accounts, setAccounts] = useState([]);
  const [bans, setBans] = useState([]);
  const [failedCodes, setFailedCodes] = useState([]);
  const [webImports, setWebImports] = useState([]);
  const [suggestions, setSuggestions] = useState([]);
  const [updates, setUpdates] = useState([]);
  const [sessions, setSessions] = useState([]);

  // Ban form
  const [banUsername, setBanUsername] = useState('');
  const [banReason, setBanReason] = useState('');
  const [banType, setBanType] = useState('other');
  const [banYears, setBanYears] = useState(1);
  const [isIpBan, setIsIpBan] = useState(false);
  const [banMsg, setBanMsg] = useState('');

  // Web import form
  const [importName, setImportName] = useState('');
  const [importUrl, setImportUrl] = useState('');

  // Update form
  const [updateVersion, setUpdateVersion] = useState('');
  const [updateDesc, setUpdateDesc] = useState('');
  const [updatePublic, setUpdatePublic] = useState(true);

  const [search, setSearch] = useState('');

  useEffect(() => {
    const u = localStorage.getItem('glora_user');
    if (!u) { navigate(createPageUrl('GloraLogin')); return; }
    const user = JSON.parse(u);
    // Block if not admin rank (allow lower_moderator = jayden to VIEW only)
    if (!ADMIN_RANKS.includes(user.rank)) {
      navigate(createPageUrl('Games'));
      return;
    }
    setCurrentUser(user);
    loadAll();
  }, []);

  // Jayden Garcia (lower_moderator) can see page but nothing works
  const isViewOnly = (user) => user?.rank === 'lower_moderator';

  const loadAll = async () => {
    setLoading(true);
    const [acc, ban, failed, imp, sug, upd, sess] = await Promise.all([
      base44.entities.GloraAccount.list(),
      base44.entities.BanRecord.list('-created_date'),
      base44.entities.FailedCode.list('-created_date'),
      base44.entities.WebImport.list('-created_date'),
      base44.entities.SuggestionReport.list('-created_date'),
      base44.entities.UpdateLog.list('-created_date'),
      base44.entities.GameSession.list(),
    ]);
    setAccounts(acc);
    setBans(ban);
    setFailedCodes(failed);
    setWebImports(imp);
    setSuggestions(sug);
    setUpdates(upd);
    setSessions(sess);
    setLoading(false);
  };

  const canBan = (targetUsername) => {
    if (!currentUser) return false;
    if (isViewOnly(currentUser)) return false; // Jayden can't do anything
    if (currentUser.rank === 'lower_admin') return false; // Riptide can't ban
    // Nobody can ban glora (owner)
    if (targetUsername.toLowerCase() === 'glora') return false;
    if (currentUser.rank === 'creator/ideas man') {
      // Green Hat can't ban owner or other creator
      const target = accounts.find(a => a.username === targetUsername.toLowerCase());
      if (target && (target.rank === 'owner' || target.rank === 'creator/ideas man')) return false;
    }
    return true;
  };

  const handleBan = async () => {
    setBanMsg('');
    if (isViewOnly(currentUser)) { setBanMsg('You are in view-only mode.'); return; }
    if (!banUsername || !banReason) { setBanMsg('Fill all fields'); return; }
    if (!canBan(banUsername)) { setBanMsg('You cannot ban this user.'); return; }

    const now = new Date();
    const unbanDate = new Date(now);
    unbanDate.setFullYear(unbanDate.getFullYear() + Math.min(Number(banYears), 50000200000000));

    // Find device id for ip ban
    const targetAccount = accounts.find(a => a.username === banUsername.toLowerCase());
    
    await base44.entities.BanRecord.create({
      username: banUsername.toLowerCase(),
      reason: banReason,
      ban_type: banType,
      banned_by: currentUser.username,
      duration_years: banYears,
      unban_date: unbanDate.toISOString(),
      is_ip_ban: isIpBan,
      device_id: targetAccount?.device_id || '',
      is_active: true
    });

    setBanMsg('User banned successfully!');
    setBanUsername(''); setBanReason(''); setBanYears(1); setIsIpBan(false);
    loadAll();
  };

  const handleUnban = async (ban) => {
    if (isViewOnly(currentUser)) return;
    await base44.entities.BanRecord.update(ban.id, { is_active: false });
    loadAll();
  };

  const handleDeleteAccount = async (id) => {
    if (isViewOnly(currentUser)) return;
    if (!window.confirm('Delete this account?')) return;
    await base44.entities.GloraAccount.delete(id);
    loadAll();
  };

  const handleAddImport = async () => {
    if (isViewOnly(currentUser)) return;
    if (!importName || !importUrl) return;
    await base44.entities.WebImport.create({ name: importName, url: importUrl, imported_by: currentUser.username });
    setImportName(''); setImportUrl('');
    loadAll();
  };

  const handleDeleteImport = async (id) => {
    if (isViewOnly(currentUser)) return;
    await base44.entities.WebImport.delete(id);
    loadAll();
  };

  const handleAddUpdate = async () => {
    if (isViewOnly(currentUser)) return;
    if (!updateVersion || !updateDesc) return;
    await base44.entities.UpdateLog.create({ version: updateVersion, description: updateDesc, is_public: updatePublic });
    setUpdateVersion(''); setUpdateDesc('');
    loadAll();
  };

  const handleSuggestionStatus = async (id, status) => {
    if (isViewOnly(currentUser)) return;
    await base44.entities.SuggestionReport.update(id, { status });
    loadAll();
  };

  const handleDismissSuggestion = async (id) => {
    if (isViewOnly(currentUser)) return;
    await base44.entities.SuggestionReport.delete(id);
    loadAll();
  };

  const getAccountStats = (username) => {
    const userSessions = sessions.filter(s => s.username === username);
    const totalMins = userSessions.reduce((sum, s) => sum + (s.minutes_played || 0), 0);
    const gamesPlayed = [...new Set(userSessions.map(s => s.game_id))].length;
    return { totalMins, gamesPlayed, sessions: userSessions.length };
  };

  if (loading || !currentUser) {
    return (
      <div className="min-h-screen bg-[#0a0a0a] flex items-center justify-center">
        <div className="text-cyan-400 animate-pulse text-xl font-bold">Loading Admin Console...</div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-[#0a0a0a] text-white flex">
      {/* Sidebar */}
      <div className="w-56 bg-[#111] border-r border-white/10 flex flex-col sticky top-0 h-screen">
        <div className="p-4 border-b border-white/10">
          <div className="flex items-center gap-2 mb-1">
            <Shield className="w-5 h-5 text-cyan-400" />
            <span className="font-black text-sm bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text text-transparent">ADMIN CONSOLE</span>
          </div>
            <div className="text-xs text-gray-300">{currentUser.username}</div>
          <div className={`text-xs font-bold ${currentUser.rank_color || 'text-gray-400'}`}>
            {currentUser.rank}
          </div>
        </div>
        <nav className="flex-1 p-2 space-y-1 overflow-y-auto">
          {TABS.map(tab => {
            const Icon = tab.icon;
            return (
              <button
                key={tab.id}
                onClick={() => setActiveTab(tab.id)}
                className={`w-full flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-all text-left ${
                  activeTab === tab.id
                    ? 'bg-cyan-500/20 text-cyan-400 border border-cyan-500/30'
                    : 'text-gray-400 hover:bg-white/5 hover:text-white'
                }`}
              >
                <Icon className="w-4 h-4 flex-shrink-0" />
                <span className="truncate">{tab.label}</span>
              </button>
            );
          })}
        </nav>
        <div className="p-4 border-t border-white/10">
          <Link to={createPageUrl('Games')} className="flex items-center gap-2 text-gray-500 hover:text-white text-sm">
            <ArrowLeft className="w-4 h-4" />
            Back to Games
          </Link>
        </div>
      </div>

      {/* Main */}
      <div className="flex-1 overflow-auto p-6">
        {isViewOnly(currentUser) && (
          <div className="mb-4 bg-orange-500/10 border border-orange-500/30 rounded-xl p-3 text-orange-400 text-sm">
            👁️ View-Only Mode — You can see everything but cannot make changes.
          </div>
        )}

        {/* ACCOUNTS TAB */}
        {activeTab === 'accounts' && (
          <div>
            <h2 className="text-xl font-black mb-4 flex items-center gap-2"><Users className="w-5 h-5 text-cyan-400" /> All Accounts ({accounts.length})</h2>
            <Input
              placeholder="Search by username..."
              value={search}
              onChange={e => setSearch(e.target.value)}
              className="bg-white/5 border-white/10 text-white mb-4 max-w-xs"
            />
            <div className="space-y-3">
              {accounts.filter(a => a.username.includes(search.toLowerCase())).map(acc => {
