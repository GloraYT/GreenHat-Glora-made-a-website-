  useEffect(() => {
    localStorage.setItem("glora_feedback", JSON.stringify(feedback));
  }, [feedback]);

  const rateGame = (gameId, userEmail, rating) => {
    setFeedback((prev) => {
      const game = prev[gameId] || { ratings: {}, comments: [] };
      return {
        ...prev,
        [gameId]: {
