const FeedbackContext = createContext();

export function FeedbackProvider({ children }) {
  const [feedback, setFeedback] = useState({});

  // Load saved feedback
  useEffect(() => {
    const saved = localStorage.getItem("glora_feedback");
    if (saved) setFeedback(JSON.parse(saved));
  }, []);

